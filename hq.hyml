<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raytown HQ</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div id="app-container">
        <header class="top-bar">
            <div class="brand-group">
                <span id="phase-tag" class="upland-blue-tag">FOUNDATION</span>
                <span id="player-rank-title">Node Builder</span>
            </div>
            <div class="wallet-display">
                <span id="tnb-balance">0.00</span> <small>TNB</small>
            </div>
        </header>

        <main id="dashboard-screen" style="display: none;">
            <div class="terminal-card">
                <h3>OPERATOR_PROFILE</h3>
                <div class="xp-container"><div id="xp-progress" class="xp-bar" style="width: 0%;"></div></div>
                <div class="data-grid">
                    <div class="data-item"><label>PROJECTS</label><span id="dash-projects">0</span></div>
                    <div class="data-item"><label>CYCLE</label><span id="dash-cycle">1</span></div>
                </div>
                <div id="manual-box" class="manual-tracker">
                    Manual Builds Done: <span id="manual-done">0</span> / <span id="manual-req">0</span>
                </div>
                <button class="action-btn" onclick="location.href='playbook.html'">READ PLAYBOOK</button>
            </div>
        </main>

        <main id="dispatch-screen">
            <div id="weather-alert" class="weather-banner" style="display:none;">⛈️ WEATHER DELAY ACTIVE (+30s)</div>
            <div class="generator-list">
                <div class="gen-card" id="gen-green">
                    <div class="gen-header"><span>G-01</span> <h3>GREEN_GEN</h3></div>
                    <p class="status-msg">STATUS: IDLE</p>
                    <div id="bot-tag" class="bot-badge" style="display:none;">🤖 BOT ACTIVE</div>
                    <button class="action-btn" onclick="startProject('green')">START BUILD</button>
                </div>
            </div>
        </main>

        <main id="market-screen" style="display: none;">
            <div class="terminal-card">
                <h3>MARKET</h3>
                <button class="action-btn" onclick="hireBot()">HIRE MGMT BOT (100 TNB)</button>
                <button class="action-btn" id="shield-btn" style="margin-top:10px; display:none;" onclick="buyShield()">BUY WEATHER SHIELD (500 TNB)</button>
            </div>
        </main>

        <main id="ceo-screen" style="display: none;">
            <div class="terminal-card ceo-vault">
                <h3>CEO_VAULT</h3>
                <p class="vault-value"><span id="ceo-treasury">0.00</span> TNB</p>
                <p class="caption">Network Revenue Split (95/5)</p>
            </div>
        </main>

        <nav class="bottom-nav">
            <button class="nav-btn" onclick="switchTab('dashboard', this)">PROFILE</button>
            <button class="nav-btn active" onclick="switchTab('dispatch', this)">DISPATCH</button>
            <button class="nav-btn" onclick="switchTab('market', this)">MARKET</button>
            <button class="nav-btn" id="ceo-nav-btn" style="display:none;" onclick="switchTab('ceo', this)">CEO</button>
        </nav>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="script.js"></script>
</body>
</html>
